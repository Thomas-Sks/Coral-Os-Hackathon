{
  "name": "@auditmesh/audit-service",
  "version": "0.1.0",
  "description": "The sold artifact — deliverService(): authorized, allowlisted security assessment via Strix (subprocess), parsed into the AuditMesh report schema",
  "type": "module",
  "engines": { "node": ">=20" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@auditmesh/shared": "file:../shared",
    "@auditmesh/authorization": "file:../authorization"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0",
    "@solana/web3.js": "^1.98.0"
  }
}
