# Copy to .env and fill in. Never commit .env — it is gitignored.

# ── Wallets (node scripts/setup.js generates these) ───────────────────────────

# Buyer keypair (base58 secret) — signs the escrow deposit/release and the TxLINE subscribe.
# Fund it at https://faucet.solana.com (GitHub sign-in; CLI/RPC airdrops are gated).
BUYER_KEYPAIR_B58=

# Seller keypair (base58 secret) — a distinct party so settlement is a real two-party transfer.
# It only RECEIVES on release, so it needs no funding. (setup.js generates this.)
SELLER_KEYPAIR_B58=

# Seller public key — the escrow's payout destination. setup.js sets this to SELLER_KEYPAIR_B58's
# pubkey. If unset, settle() self-pays the buyer (one-wallet demo; not a real two-party transfer).
WALLET=

# Arbiter keypair (base58 secret) — the neutral 3rd signer that gates release/refund (the trustless
# wrapper, examples/txodds/escrow/programs/arbiter). When set, settle() routes through the arbiter so
# the buyer can't take delivery and refund. Needs only tx-fee funds — the proxy tops it up from the
# buyer automatically. If unset, settle() falls back to the direct buyer-released escrow. (setup.js generates this.)
ARBITER_KEYPAIR_B58=

SOLANA_RPC_URL=https://api.devnet.solana.com

# ── LLM brain (the agent's reasoning + delivery) ──────────────────────────────

# This kit's LLM is Venice AI — OpenAI-compatible, with free credits. Create a key at
# https://venice.ai/settings/api; new accounts get $50 free with redeem code IMPERIAL50 (bottom of that
# page). Recommended: set both of these.
#   LLM_PROVIDER=venice
VENICE_API_KEY=

# Alternatives (no code change) — set LLM_PROVIDER + the matching key:
#   LLM_PROVIDER=openai      → OPENAI_API_KEY=...
#   LLM_PROVIDER=anthropic   → ANTHROPIC_API_KEY=...
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LLM_PROVIDER=
LLM_MODEL=

# ── TxLINE (optional) ─────────────────────────────────────────────────────────
# The proxy subscribes the buyer wallet to the free World Cup tier on its own, so you don't need to
# set these. `npm run mint` (examples/txodds) writes TXLINE_API_KEY here for the standalone TxLineClient.
TXLINE_API_KEY=
TXLINE_BASE_URL=

# Override the TxLINE devnet ids if TxODDS rotates them (defaults are baked into the proxy):
TXLINE_PROGRAM=          # subscription program id (default 6pW64…P2J)
TXLINE_MINT=             # treasury token mint    (default 4Zao8o…EokRG)

# ── AuditMesh (the security-audit marketplace — `npm run demo`) ───────────────
# The scanner may ONLY target the bundled, self-hosted OWASP Juice Shop (front-door on :8899). The
# allowlist is hardcoded in packages/shared/src/config.ts and cannot be widened to an external URL.

# The allowlisted target the sellers assess. Inside the compose network use the front-door hostname;
# if coral spawns agents on a different network, use http://host.docker.internal:8899 (also allowlisted).
AUDIT_TARGET=http://target-frontdoor

# Report source: `prebaked` replays a stored REAL Strix report (deterministic filmed demo, no Strix/Docker
# needed); `live` runs a fresh Strix scan (needs Docker-in-Docker + LLM_API_KEY). Settlement is ALWAYS
# live on devnet regardless.
REPORT_SOURCE=prebaked

# Strix engine (live mode only). Model in provider/model form; the key Strix uses is LLM_API_KEY.
SCAN_MODE=quick
STRIX_LLM=anthropic/claude-sonnet-4-6
LLM_API_KEY=

# Buyer economics + requested scope. Budget caps every bid. AUDIT_SCOPES is a csv of per-round scopes
# (short codes joined by +: hdr,tls,inj,xss,auth,ac,data,dep,biz), rotated so different personas win.
BUYER_MAX_SOL=0.02
AUDIT_SCOPES=hdr+tls,hdr+tls+xss+inj+ac+data,hdr+tls+xss
AUDIT_EXCLUSIONS=/#/administration

# arbiter (default, trustless — buyer can't take delivery AND refund) | direct (base escrow).
SETTLEMENT_MODE=arbiter

# Pace the delivery-graph stages (ms) so the "graph inside a graph" is watchable in prebaked mode.
DELIVERY_PACING_MS=1200

# AUTHZ_NONCE is generated + published to the target's /.well-known by `npm run demo` — leave unset.
AUTHZ_NONCE=
